[3.226, "o", "\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2557\u2588\u2588\u2551\u001b[0m               \u001b[34m\u2502\u001b[0m\r\n\u001b[34m\u2502\u001b[0m \u001b[1;36m\u255a\u2550\u255d  \u255a\u2550\u2550\u2550\u255d \u255a\u2550\u2550\u2550\u2550\u2550\u255d    \u255a\u2550\u255d   \u255a\u2550\u2550\u2550\u2550\u2550\u2550\u255d\u255a\u2550\u2550\u2550\u2550\u2550\u2550\u255d\u255a\u2550\u255d\u001b[0m               \u001b[34m\u2502\u001b[0m\r\n\u001b[34m\u2502\u001b[0m                                                               \u001b[34m\u2502\u001b[0m\r\n\u001b[34m\u2502\u001b[0m Paste or type anything to capture it. The AI will figure out  \u001b[34m\u2502\u001b[0m\r\n\u001b[34m\u2502\u001b[0m whether it's a note, a todo, or an idea.                      \u001b[34m\u2502\u001b[0m\r\n\u001b[34m\u2502\u001b[0m                                                               \u001b[34m\u2502\u001b[0m\r\n\u001b[34m\u2502\u001b[0m \u001b[1mEnter\u001b[0m for new lines, \u001b[1mEnter twice\u001b[0m to submit.                   \u001b[34m\u2502\u001b[0m\r\n\u001b[34m\u2502\u001b[0m Type \u001b[36m/help\u001b[0m for commands, \u001b[36m/quit\u001b[0m to exit.                       \u001b[34m\u2502\u001b[0m\r\n\u001b[34m\u2570\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256f\u001b[0m\r\n"]
